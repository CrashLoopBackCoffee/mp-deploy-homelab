{
    $schema: 'https://docs.renovatebot.com/renovate-schema.json',
    extends: [
        'config:recommended',
        ':dependencyDashboard',
    ],
    mode: 'full',
    minimumReleaseAge: '7 days',
    internalChecksFilter: 'strict',
    lockFileMaintenance: {
        enabled: true,
    },
    customManagers: [
        {
            customType: 'regex',
            managerFilePatterns: [
                '/(^|/)Dockerfile$/',
            ],
            matchStrings: [
                '# renovate: datasource=(?<datasource>[a-z-]+?)(?: depName=(?<depName>.+?))? packageName=(?<packageName>.+?)(?: versioning=(?<versioning>[a-z-]+?))?\\sARG \\S+?=(?<currentValue>\\S+)',
            ],
            versioningTemplate: '{{#if versioning}}{{versioning}}{{else}}semver{{/if}}',
        },
        {
            customType: 'regex',
            managerFilePatterns: [
                '/\\.ya?ml$/',
            ],
            matchStrings: [
                '# renovate: datasource=(?<datasource>[a-z-]+?)(?: depName=(?<depName>.+?))?(?: registryUrl=(?<registryUrl>.+?))? packageName=(?<packageName>.+?)(?: versioning=(?<versioning>[a-z0-9-]+?))?\\s+[a-zA-Z_-]+:\\s+"?(?<currentValue>[^"\\s]+)"?',
            ],
            versioningTemplate: '{{#if versioning}}{{versioning}}{{else}}semver{{/if}}',
        },
    ],
    packageRules: [
        {
            matchPackageNames: ['canonical/microk8s'],
            separateMultipleMinor: true,
            minimumReleaseAge: '21 days',
        },
        {
            matchUpdateTypes: ['major'],
            minimumReleaseAge: '10 days',
        },
    ],
    vulnerabilityAlerts: {
        enabled: true,
        dependencyDashboardApproval: false,
        labels: ['security'],
    },
    prHourlyLimit: 10,
    rangeStrategy: 'replace',
}
